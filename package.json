{
  "name": "utopiajs",
  "private": true,
  "version": "0.8.1",
  "description": "A compiler-first, signal-based UI framework with single-file components",
  "type": "module",
  "license": "MIT",
  "author": "Matt <matt@matthesketh.pro>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wrxck/utopiajs.git"
  },
  "homepage": "https://matthesketh.pro",
  "bugs": "https://github.com/wrxck/utopiajs/issues",
  "keywords": [
    "ui",
    "framework",
    "signals",
    "reactive",
    "compiler",
    "ssr",
    "sfc",
    "components",
    "typescript"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint packages/*/src/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts' 'packages/*/package.json' 'package.json' '*.js'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts' 'packages/*/package.json' 'package.json' '*.js'",
    "clean": "pnpm -r exec rm -rf dist",
    "release": "pnpm build && pnpm -r publish --access public"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "eslint": "10.4.1",
    "globals": "17.6.0",
    "happy-dom": "20.9.0",
    "prettier": "3.8.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@esbuild/linux-x64": "0.28.0",
    "@vitest/runner": "4.1.7",
    "jsdom": "29.1.1"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0"
    }
  }
}
