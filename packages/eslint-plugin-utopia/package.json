{
  "name": "@matthesketh/eslint-plugin-utopia",
  "version": "0.8.1",
  "description": "ESLint parser + rules for .utopia single-file components",
  "type": "module",
  "license": "MIT",
  "author": "Matt <matt@matthesketh.pro>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wrxck/utopiajs.git",
    "directory": "packages/eslint-plugin-utopia"
  },
  "homepage": "https://github.com/wrxck/utopiajs/tree/main/packages/eslint-plugin-utopia",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "utopiajs",
    "sfc",
    "linting"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0 || ^10.0.0"
  },
  "dependencies": {
    "@matthesketh/utopia-compiler": "workspace:*",
    "@typescript-eslint/parser": "8.60.0"
  }
}
