{
  "name": "@matthesketh/prettier-plugin-utopia",
  "version": "0.8.1",
  "description": "Prettier plugin for .utopia single-file components",
  "type": "module",
  "license": "MIT",
  "author": "Matt <matt@matthesketh.pro>",
  "repository": {
    "type": "git",
    "url": "https://github.com/wrxck/utopiajs.git",
    "directory": "packages/prettier-plugin-utopia"
  },
  "homepage": "https://github.com/wrxck/utopiajs/tree/main/packages/prettier-plugin-utopia",
  "keywords": [
    "prettier",
    "prettier-plugin",
    "utopiajs",
    "sfc",
    "formatting"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  }
}
